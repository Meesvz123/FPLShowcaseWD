@model IReadOnlyList<FPL_Showcase_WD.Models.FantasyTeam>
@{
    Layout = null;
    var totalTeams = Model?.Count ?? 0;
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alle teams</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
</head>
<body class="admin-body">
    <main class="page page--admin">
        <section class="card card--admin">
            <header class="team-header admin-header">
                <div>
                    <h1 class="title">Alle teams</h1>
                    <p class="subtitle">Overzicht van alle ingediende fantasy teams.</p>
                </div>
                <form asp-controller="Login" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-button">Uitloggen</button>
                </form>
            </header>

            <section class="admin-stats" aria-label="Admin statistieken">
                <div class="stat-card">
                    <span class="stat-label">Teams</span>
                    <span class="stat-value">@totalTeams</span>
                </div>
            </section>

            <div class="table-wrap">
                <table class="team-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Gebruiker</th>
                            <th>Gemaakt</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var team in Model)
                    {
                        <tr>
                            <td>@team.Name</td>
                            <td>@(team.ApplicationUser?.Email ?? "-")</td>
                            <td>@team.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                            <td class="table-actions">
                                <a class="action-link" asp-action="Edit" asp-route-id="@team.Id">Aanpassen</a>
                                <form asp-action="Delete" asp-route-id="@team.Id" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="action-link action-link--danger" onclick="return confirm('Team verwijderen?')">Verwijderen</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script>
        // This script can be used for any future JavaScript functionality
        $(document).ready(function () {
            console.log("Admin teams page ready.");
        });
    </script>
</body>
</html>