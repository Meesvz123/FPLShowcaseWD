@model FPL_Showcase_WD.Models.LoginViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@tokens.RequestToken" />
    <title>Login</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
<main class="page page--login">
    <section class="card card--login">
        <h1 class="title">Login</h1>
        <form method="post" class="login-form">
            @Html.AntiForgeryToken()
            <label>
                Email
                <input asp-for="Email" type="email" autocomplete="username" />
            </label>
            <label>
                Wachtwoord
                <input asp-for="Password" type="password" autocomplete="current-password" />
            </label>
            <label class="login-remember">
                <input asp-for="RememberMe" type="checkbox" />
                Onthoud mij
            </label>
            <button type="submit">Inloggen</button>
            <div asp-validation-summary="All" class="validation-summary"></div>
            <p class="auth-link">
                Nog geen account?
                <a asp-controller="Register" asp-action="Index">Registreer</a>
            </p>
        </form>
    </section>
</main>
</body>
</html>